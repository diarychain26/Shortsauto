# LLM (현재는 mock 사용. 추후 openai/claude/gemini 연결 가능)
LLM_PROVIDER=mock

# IMAGE
# pillow(기본 카드 생성) | gemini(나노바나나)
IMAGE_PROVIDER=gemini

# ✅ Gemini 인증 방식 선택
# 1) API 키 방식(Developer API)
#    - 아래 GEMINI_API_KEY 사용
#    - 일반적으로 과금 발생
GEMINI_API_KEY=

# 2) OAuth/ADC 방식(Vertex AI)
#    - GOOGLE_GENAI_USE_VERTEXAI=true
#    - gcloud auth application-default login 또는 서비스계정(ADC)
#    - 여전히 프로젝트 과금/쿼터가 적용됨(인증만 다름)
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# 모델
# Nano Banana(빠름): gemini-2.5-flash-image
# Nano Banana Pro(고품질): gemini-3-pro-image-preview
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# TTS
TTS_PROVIDER=edge
# TTS_PROVIDER=typecast

# Typecast (연동 시)
TYPECAST_API_KEY=
TYPECAST_VOICE_ID=
